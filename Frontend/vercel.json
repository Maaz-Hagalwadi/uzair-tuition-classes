{
  "rewrites": [
    { "source": "/api/:path*",              "destination": "https://YOUR_RENDER_URL/api/:path*" },
    { "source": "/oauth2/:path*",           "destination": "https://YOUR_RENDER_URL/oauth2/:path*" },
    { "source": "/((?!api|oauth2).*)",      "destination": "/index.html" }
  ]
}
